          "specialty": {
            "type": "string",
            "enum": [
              "cardiology",
              "dermatology",
              "orthopedics",
              "neurology",
              "mental_health",
              "endocrinology"
            ]
          }
        },
        "required": [
          "specialty"
        ]
      }
