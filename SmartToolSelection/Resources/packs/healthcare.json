      "parameters": {
        "type": "object",
        "properties": {
          "specialty": {
            "type": "string",
            "enum": [
              "primary_care",
              "cardiology",
              "dermatology",
              "pediatrics",
              "orthopedics",
              "mental_health"
            ]
          }
        },
        "required": []
      },
      "keywords": [
        "see a doctor",
        "find a doctor",
        "need a doctor",
        "doctor near me",
        "find a specialist",
        "I'm sick",
        "find a clinic"
      ]
    },
    {
      "name": "get_insurance_coverage",
      "description": "Look up what the patient's insurance plan covers.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
