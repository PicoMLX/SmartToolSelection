{
  "name": "healthcare",
  "description": "Patient-facing scheduling, records, prescriptions, and insurance tools (FHIR-style).",
  "tools": [
    {
      "name": "book_appointment",
      "description": "Schedule a medical appointment with a provider.",
      "parameters": {
        "type": "object",
        "properties": {
          "visit_type": {
            "type": "string",
            "enum": [
              "in_person",
              "telehealth",
              "urgent_care",
              "follow_up"
            ]
          },
          "specialty": {
            "type": "string",
            "enum": [
              "primary_care",
              "cardiology",
              "dermatology",
              "pediatrics",
              "orthopedics",
              "mental_health"
            ]
          }
        },
        "required": []
      }
    },
    {
      "name": "cancel_appointment",
      "description": "Cancel a scheduled appointment.",
      "parameters": {
        "type": "object",
        "properties": {
          "appointment_id": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "enum": [
              "feeling_better",
              "scheduling_conflict",
              "found_other_provider",
              "cost",
              "transportation"
            ]
          }
        },
        "required": [
          "appointment_id"
        ]
      }
    },
    {
      "name": "reschedule_appointment",
      "description": "Move an existing appointment to a new time.",
      "parameters": {
        "type": "object",
        "properties": {
          "appointment_id": {
            "type": "string"
          }
        },
        "required": [
          "appointment_id"
        ]
      }
    },
    {
      "name": "request_prescription_refill",
      "description": "Request a refill for an existing prescription.",
      "parameters": {
        "type": "object",
        "properties": {
          "medication": {
            "type": "string"
          }
        },
        "required": [
          "medication"
        ]
      }
    },
    {
      "name": "check_prescription_status",
      "description": "Check whether a prescription is ready at the pharmacy.",
      "parameters": {
        "type": "object",
        "properties": {
          "medication": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "filled",
              "denied",
              "expired"
            ]
          }
        },
        "required": []
      }
    },
    {
      "name": "get_lab_results",
      "description": "Retrieve results from completed lab tests.",
      "parameters": {
        "type": "object",
        "properties": {
          "test_type": {
            "type": "string",
            "enum": [
              "blood_panel",
              "urinalysis",
              "imaging",
              "biopsy",
              "covid",
              "allergy"
            ]
          }
        },
        "required": []
      }
    },
    {
      "name": "order_lab_test",
      "description": "Order a new laboratory or diagnostic test.",
      "parameters": {
        "type": "object",
        "properties": {
          "test_type": {
            "type": "string",
            "enum": [
              "blood_panel",
              "urinalysis",
              "imaging",
              "biopsy",
              "covid",
              "allergy"
            ]
          }
        },
        "required": [
          "test_type"
        ]
      }
    },
    {
      "name": "get_medical_records",
      "description": "Retrieve the patient's medical record history.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "share_records_with_provider",
      "description": "Share medical records with another provider or clinic.",
      "parameters": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "provider"
        ]
      }
    },
    {
      "name": "message_provider",
      "description": "Send a secure message to the care team.",
      "parameters": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string"
          },
          "urgency": {
            "type": "string",
            "enum": [
              "routine",
              "urgent",
              "emergency"
            ]
          }
        },
        "required": [
          "body"
        ]
      }
    },
    {
      "name": "get_vitals_history",
      "description": "View recorded vital-sign measurements over time.",
      "parameters": {
        "type": "object",
        "properties": {
          "metric": {
            "type": "string",
            "enum": [
              "blood_pressure",
              "heart_rate",
              "weight",
              "glucose",
              "temperature",
              "oxygen"
            ]
          }
        },
        "required": []
      }
    },
    {
      "name": "log_symptom",
