      "parameters": {
        "type": "object",
        "properties": {
          "leave_type": {
            "type": "string",
            "enum": [
              "vacation",
              "sick",
              "personal",
              "parental",
              "bereavement",
              "jury_duty"
            ]
          }
        },
        "required": [
          "leave_type"
        ]
      },
      "keywords": [
        "time off",
        "take time off",
        "need time off",
        "request time off",
        "book a vacation",
        "take a vacation",
        "going on vacation",
        "request leave",
        "take leave",
        "book holiday",
        "out of office next week"
      ]
    },
    {
